#!/bin/bash
TF_DIR="/home/user/iths/grand_lab/terraform"

# Get values from Terraform
TERRA_BASTION=$(terraform -chdir="$TF_DIR" output -raw bastion_ip)
TERRA_NEXTCLOUD=$(terraform -chdir="$TF_DIR" output -raw nextcloud_ip)

# ask for input
read -p "Ange Bastion IP [$TERRA_BASTION]: " INPUT_BASTION
INPUT_BASTION=${INPUT_BASTION:-$TERRA_BASTION}

read -p "Ange Nextcloud IP [$TERRA_NEXTCLOUD]: " INPUT_NEXTCLOUD
INPUT_NEXTCLOUD=${INPUT_NEXTCLOUD:-$TERRA_NEXTCLOUD}

# create inventory.ini
cat <<EOF > inventory.ini
[nextcloud]
$INPUT_NEXTCLOUD ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/id_rsa

[nextcloud:vars]
ansible_ssh_common_args='-o StrictHostKeyChecking=no -o ProxyCommand="ssh -W %h:%p -q -i ~/.ssh/id_rsa ubuntu@$INPUT_BASTION -o StrictHostKeyChecking=no"'
EOF

echo "inventory.ini updated"
